# =============================================================================
# poster-consistency-dinov3 — 项目环境变量模板
# =============================================================================
# 用法:
#   cp .env.example .env
#   # 然后:
#   set -a && source .env && set +a
#
# 这些值只在当前 shell session 内生效,不会污染 ~/.bashrc 或其他项目。
# 详情:AGENTS.md R5(网络)、R3(磁盘缓存)、docs/02-environment-setup.md
# =============================================================================

# -----------------------------------------------------------------------------
# 网络:HF / PyPI 镜像加速(本机无 mihomo 透明代理,必须显式配置)
# -----------------------------------------------------------------------------

# Hugging Face 国内镜像(huggingface-cli / transformers 都会读这个)
export HF_ENDPOINT=https://hf-mirror.com

# uv / pip 默认源(清华)
export UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple

# uv 下载超时:默认 30s 太短,PyTorch wheel 经常超时
export UV_HTTP_TIMEOUT=300

# -----------------------------------------------------------------------------
# 缓存重定向:全部落项目目录,避免污染 ~/.cache/ 和系统盘
# 必须与 models/ 同盘,否则 HF 符号链接会降级为物理复制(见 docs/03 §4)
# -----------------------------------------------------------------------------

# Hugging Face 缓存根
export HF_HOME=/opt/workspace/yongli/poster-consistency-dinov3/.hf_cache

# uv 包缓存
export UV_CACHE_DIR=/opt/workspace/yongli/poster-consistency-dinov3/.uv_cache

# (可选)PyTorch hub 缓存
export TORCH_HOME=/opt/workspace/yongli/poster-consistency-dinov3/.torch_cache

# -----------------------------------------------------------------------------
# CUDA / 性能(可选)
# -----------------------------------------------------------------------------

# 强制单卡(本机就一张 5090,显式声明防误用)
export CUDA_VISIBLE_DEVICES=0

# 关闭 tokenizer 并行警告
export TOKENIZERS_PARALLELISM=false

# -----------------------------------------------------------------------------
# 业务参数占位(后续 Phase 用到再填)
# -----------------------------------------------------------------------------

# DINOv3 模型路径(Phase 1 之后填实际值)
# export DINOV3_MODEL_PATH=/opt/workspace/yongli/poster-consistency-dinov3/models/dinov3-large

# HF token(如需访问 gated 模型,**绝不**把真实值 commit 进 git!)
# export HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
